include tests/test_foa_experimental_dl.py
include tests/test_import_contract.py
include tests/test_ambi_encoder.py
include tests/test_ambi_format.py
include tests/test_ambi_intensity.py
include tests/test_ambi_io.py
include tests/test_ambi_to_binaural.py
include tests/test_ambi_translation.py
include tests/test_ambi_uhj.py
