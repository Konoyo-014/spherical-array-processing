prune .claude
prune .github
prune .pytest_cache
prune Spherical-Array-Opensource-Pythonic
prune _nonopensource_extras_bundle
prune _rafaely_plot_bundle
prune artifacts
prune build
prune dist
prune examples/rafaely
prune scripts
prune src

global-exclude .DS_Store
global-exclude *.py[cod]
global-exclude __pycache__
